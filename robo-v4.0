/**
 * @file robo-v4.0.js
 * @description Robô de automação para extração de relatórios da Assim, upload para Órbita e Google Drive,
 *              com notificações via Slack. Este arquivo incorpora melhorias de robustez, observabilidade
 *              e modularidade, mantendo a lógica original.
 * @author Seu Nome / Equipe de Automação
 * @version 4.0
 * @date 20 de março de 2026
 */

// --- IMPORTS ---
const { chromium } = require('playwright');
const fs = require('fs');
const path = require('path');
const XLSX = require('xlsx'); // Certifique-se de ter 'xlsx' instalado: npm install xlsx

// --- HELPERS ---

/**
 * @class RetryableError
 * @extends Error
 * @description Erro que indica uma falha temporária e que pode ser recuperada com uma nova tentativa.
 */
class RetryableError extends Error {
  constructor(message) {
    super(message);
    this.name = 'RetryableError';
  }
}

/**
 * @class FatalError
 * @extends Error
 * @description Erro que indica uma falha permanente e que não deve ser retentada.
 */
class FatalError extends Error {
  constructor(message) {
    super(message);
    this.name = 'FatalError';
  }
}

/**
 * @function logStructured
 * @description Registra mensagens de log em formato JSON para console e arquivo.
 * @param {string} level - Nível do log (INFO, WARN, ERROR, SUCCESS).
 * @param {string} message - Mensagem principal do log.
 * @param {object} [metadata={}] - Metadados adicionais para o log.
 */
function logStructured(level, message, metadata = {}) {
  const logEntry = {
    timestamp: new Date().toISOString(),
    level,
    message,
    executionId: process.env.GITHUB_RUN_ID || 'local',
    ...metadata
  };

  console.log(JSON.stringify(logEntry));

  const logDir = 'logs';
  if (!fs.existsSync(logDir)) {
    fs.mkdirSync(logDir);
  }
  const logFile = path.join(logDir, `${new Date().toISOString().split('T')[0]}.jsonl`);
  fs.appendFileSync(logFile, JSON.stringify(logEntry) + '
');
}

/**
 * @function withRetry
 * @description Executa uma função assíncrona com lógica de retry e backoff exponencial.
 * @param {Function} fn - A função assíncrona a ser executada.
 * @param {object} [options={}] - Opções de retry.
 * @param {number} [options.maxAttempts=3] - Número máximo de tentativas.
 * @param {number} [options.initialDelay=1000] - Atraso inicial em ms antes da primeira retry.
 * @param {number} [options.backoffMultiplier=2] - Multiplicador para o atraso exponencial.
 * @param {boolean} [options.jitter=true] - Adiciona um atraso aleatório para evitar picos de requisição.
 * @param {Function} [options.retryOn=(err) => err instanceof RetryableError] - Função para determinar se um erro deve ser retentado.
 * @returns {Promise} O resultado da função `fn`.
 * @throws {Error} O último erro se todas as tentativas falharem.
 */
async function withRetry(fn, options = {}) {
  const {
    maxAttempts = 3,
    initialDelay = 1000,
    backoffMultiplier = 2,
    jitter = true,
    retryOn = (err) => err instanceof RetryableError
  } = options;

  let lastError;
  for (let attempt = 1; attempt <= maxAttempts; attempt++) {
    try {
      return await fn();
    } catch (err) {
      lastError = err;
      if (attempt === maxAttempts || !retryOn(err)) {
        throw err; // Lança o erro se for a última tentativa ou não for um erro retentável
      }

      let delay = initialDelay * Math.pow(backoffMultiplier, attempt - 1);
      if (jitter) delay *= (0.5 + Math.random()); // Adiciona jitter
      delay = Math.min(delay, 30000); // Limita o delay máximo a 30 segundos

      logStructured('WARN', `Tentativa ${attempt}/${maxAttempts} falhou. Aguardando ${delay}ms...`, {
        error: err.message,
        attempt
      });
      await new Promise(r => setTimeout(r, delay));
    }
  }
  throw lastError; // Deve ser inalcançável se o erro for lançado acima
}

/**
 * @class CircuitBreaker
 * @description Implementa o padrão Circuit Breaker para proteger contra falhas em cascata.
 */
class CircuitBreaker {
  /**
   * @param {number} threshold - Número de falhas consecutivas para abrir o circuito.
   * @param {number} timeout - Tempo em ms que o circuito permanece aberto antes de tentar HALF_OPEN.
   */
  constructor(threshold = 5, timeout = 300000) { // 5 minutos
    this.failureCount = 0;
    this.threshold = threshold;
    this.timeout = timeout;
    this.state = 'CLOSED'; // CLOSED, OPEN, HALF_OPEN
    this.lastFailureTime = null;
  }

  /**
   * @description Executa uma função, aplicando a lógica do Circuit Breaker.
   * @param {Function} fn - A função a ser executada.
   * @returns {Promise} O resultado da função `fn`.
   * @throws {Error} Se o circuito estiver aberto.
   */
  async execute(fn) {
    if (this.state === 'OPEN') {
      if (Date.now() - this.lastFailureTime > this.timeout) {
        this.state = 'HALF_OPEN';
        logStructured('INFO', 'Circuit Breaker: Transicionando para HALF_OPEN. Tentando recuperar...');
      } else {
        const remainingTime = Math.ceil((this.timeout - (Date.now() - this.lastFailureTime)) / 1000);
        throw new Error(`Circuit Breaker está OPEN. Tente novamente em ${remainingTime}s.`);
      }
    }

    try {
      const result = await fn();
      this.onSuccess();
      return result;
    } catch (err) {
      this.onFailure();
      throw err;
    }
  }

  /**
   * @description Chamado quando a função é executada com sucesso.
   */
  onSuccess() {
    if (this.state !== 'CLOSED') {
      logStructured('SUCCESS', 'Circuit Breaker: Recuperado. Transicionando para CLOSED.');
    }
    this.failureCount = 0;
    this.state = 'CLOSED';
  }

  /**
   * @description Chamado quando a função falha.
   */
  onFailure() {
    this.failureCount++;
    this.lastFailureTime = Date.now();
    if (this.failureCount >= this.threshold && this.state !== 'OPEN') {
      this.state = 'OPEN';
      logStructured('ERROR', `Circuit Breaker: ABERTO após ${this.failureCount} falhas consecutivas.`, {
        threshold: this.threshold
      });
    }
  }
}

/**
 * @class ExecutionMetrics
 * @description Coleta métricas de tempo e eventos durante a execução do robô.
 */
class ExecutionMetrics {
  constructor() {
    this.startTime = Date.now();
    this.events = [];
  }

  /**
   * @description Registra um evento na linha do tempo da execução.
   * @param {string} name - Nome do evento (ex: 'loginAssim', 'extrairRelatorio').
   * @param {number} duration - Duração do evento em milissegundos.
   * @param {string} [status='success'] - Status do evento (success, failure, warn).
   * @param {object} [metadata={}] - Metadados adicionais para o evento.
   */
  recordEvent(name, duration, status = 'success', metadata = {}) {
    this.events.push({
      name,
      duration,
      status,
      timestamp: new Date().toISOString(),
      ...metadata
    });
  }

  /**
   * @description Gera um resumo das métricas coletadas.
   * @returns {object} Um objeto contendo o resumo da execução.
   */
  summary() {
    const totalDuration = Date.now() - this.startTime;
    const successfulEvents = this.events.filter(e => e.status === 'success').length;
    const failedEvents = this.events.filter(e => e.status === 'failure').length;

    return {
      totalDuration,
      eventCount: this.events.length,
      successfulEvents,
      failedEvents,
      successRate: this.events.length > 0 ? successfulEvents / this.events.length : 0,
      events: this.events,
      slowestEvent: this.events.length > 0 ? this.events.reduce((a, b) => a.duration > b.duration ? a : b) : null
    };
  }
}

/**
 * @function validateEnv
 * @description Valida a presença e o formato das variáveis de ambiente necessárias.
 * @throws {FatalError} Se alguma variável de ambiente estiver ausente ou inválida.
 */
function validateEnv() {
  const required = ['SENHA', 'ORBITA_USER', 'ORBITA_PASS', 'GOOGLE_SCRIPT_URL', 'SLACK_WEBHOOK'];
  const missing = required.filter(v => !process.env[v]);

  if (missing.length > 0) {
    throw new FatalError(`Variáveis de ambiente ausentes: ${missing.join(', ')}. Por favor, configure-as.`);
  }

  const urlVars = {
    GOOGLE_SCRIPT_URL: process.env.GOOGLE_SCRIPT_URL,
    SLACK_WEBHOOK: process.env.SLACK_WEBHOOK
  };

  for (const [key, value] of Object.entries(urlVars)) {
    try {
      new URL(value);
    } catch {
      throw new FatalError(`Variável de ambiente ${key} não é uma URL válida: ${value}.`);
    }
  }

  logStructured('INFO', 'Todas as variáveis de ambiente validadas com sucesso.');
}

/**
 * @function dentroDoHorario
 * @description Verifica se a execução está dentro do horário comercial (Seg-Sex, 8:30-18:00).
 * @returns {boolean} True se estiver dentro do horário, False caso contrário.
 */
function dentroDoHorario() {
  const now = new Date();
  const day = now.getDay(); // 0 = Domingo, 1 = Segunda, ..., 6 = Sábado
  const hour = now.getHours();
  const minute = now.getMinutes();

  // Verifica se é dia de semana (Segunda a Sexta)
  if (day >= 1 && day <= 5) {
    // Verifica se está entre 8:30 e 18:00
    if (hour > 8 && hour < 18) {
      return true;
    }
    if (hour === 8 && minute >= 30) {
      return true;
    }
  }
  return false;
}

// --- SERVICES ---

/**
 * @class AssimService
 * @description Serviço para interagir com o portal Assim.
 */
class AssimService {
  /**
   * @param {import('playwright').Page} page - Instância da página do Playwright.
   */
  constructor(page) {
    this.page = page;
    this.baseUrl = 'https://sirius.assim.com.br/assimcsp/autorizador/';
  }

  /**
   * @description Realiza o login no portal Assim.
   * @param {string} usuario - Usuário de login.
   * @param {string} senha - Senha de login.
   * @throws {RetryableError} Se houver um erro temporário no login.
   * @throws {FatalError} Se o login falhar devido a credenciais inválidas ou mudança na página.
   */
  async login(usuario, senha) {
    logStructured('INFO', 'Iniciando login no portal Assim...');
    try {
      await withRetry(async () => {
        await this.page.goto(`${this.baseUrl}login.csp`, { waitUntil: 'domcontentloaded', timeout: 60000 });
        await this.page.fill('input[type="email"]', usuario);
        await this.page.fill('input[type="password"]', senha);
        await this.page.click('button[type="submit"]');

        // Espera por um elemento que indica sucesso ou falha no login
        const loginSuccess = await this.page.waitForURL(url => url.includes('home.csp') || url.includes('preresultado.csp'), { timeout: 30000 }).catch(() => null);
        if (loginSuccess) {
          logStructured('SUCCESS', 'Login no portal Assim realizado com sucesso.');
          return;
        }

        const errorMessage = await this.page.locator('.alert-danger').textContent().catch(() => null);
        if (errorMessage && errorMessage.includes('Usuário ou senha inválidos')) {
          throw new FatalError(`Login Assim falhou: ${errorMessage.trim()}`);
        }
        throw new RetryableError('Login Assim falhou ou página inesperada após login.');
      }, {
        retryOn: (err) => err instanceof RetryableError || err.message.includes('timeout')
      });
    } catch (error) {
      if (error instanceof FatalError) throw error;
      throw new FatalError(`Falha crítica ao tentar login no Assim: ${error.message}`);
    }
  }

  /**
   * @description Extrai dados de relatório do portal Assim.
   * @param {string} urlConsulta - URL específica para a consulta do relatório.
   * @returns {Promise>} Array de objetos com os dados extraídos.
   * @throws {RetryableError} Se houver um erro temporário na extração.
   * @throws {FatalError} Se a estrutura da página mudar ou a extração falhar permanentemente.
   */
  async extractReport(urlConsulta) {
    logStructured('INFO', `Iniciando extração de relatório da Assim da URL: ${urlConsulta}`);
    let extractedData = [];
    try {
      await withRetry(async () => {
        await this.page.goto(urlConsulta, { waitUntil: 'networkidle', timeout: 90000 }); // Aumentado timeout para extração
        
        // Lógica para extrair dados da tabela
        const tableRows = await this.page.$$('table tbody tr');
        if (tableRows.length === 0) {
          logStructured('WARN', 'Nenhum dado encontrado na tabela do relatório Assim.', { url: urlConsulta });
          return;
        }

        const headers = await this.page.$$eval('table thead th', ths => ths.map(th => th.textContent.trim()));
        
        for (const row of tableRows) {
          const cells = await row.$$eval('td', tds => tds.map(td => td.textContent.trim()));
          if (cells.length === headers.length) {
            let rowData = {};
            for (let i = 0; i < headers.length; i++) {
              rowData[headers[i]] = cells[i];
            }
            extractedData.push(rowData);
          }
        }
        logStructured('SUCCESS', `Extração de relatório Assim concluída. Registros: ${extractedData.length}`, { url: urlConsulta });
      }, {
        retryOn: (err) => err instanceof RetryableError || err.message.includes('timeout') || err.message.includes('selector')
      });
    } catch (error) {
      if (error instanceof FatalError) throw error;
      throw new FatalError(`Falha crítica ao extrair relatório do Assim: ${error.message}`);
    }
    return extractedData;
  }
}

/**
 * @class OrbitaService
 * @description Serviço para interagir com o portal Órbita.
 */
class OrbitaService {
  /**
   * @param {import('playwright').Page} page - Instância da página do Playwright.
   */
  constructor(page) {
    this.page = page;
    this.baseUrl = 'https://cronogramauniversoaba.com.br/';
  }

  /**
   * @description Realiza o login no portal Órbita.
   * @param {string} usuario - Usuário de login.
   * @param {string} senha - Senha de login.
   * @throws {RetryableError} Se houver um erro temporário no login.
   * @throws {FatalError} Se o login falhar devido a credenciais inválidas ou mudança na página.
   */
  async login(usuario, senha) {
    logStructured('INFO', 'Iniciando login no portal Órbita...');
    try {
      await withRetry(async () => {
        await this.page.goto(`${this.baseUrl}app_Login/`, { waitUntil: 'domcontentloaded', timeout: 60000 });
        await this.page.fill('input[name="usuario"]', usuario);
        await this.page.fill('input[name="senha"]', senha);
        await this.page.click('button');

        // Espera por um elemento que indica sucesso ou falha no login
        const loginSuccess = await this.page.waitForURL(url => url.includes('app_Menu') || url.includes('app_Login') === false, { timeout: 30000 }).catch(() => null);
        if (loginSuccess) {
          logStructured('SUCCESS', 'Login no portal Órbita realizado com sucesso.');
          return;
        }

        const errorMessage = await this.page.locator('.alert-danger').textContent().catch(() => null); // Exemplo de seletor de erro
        if (errorMessage && errorMessage.includes('Usuário ou senha inválidos')) {
          throw new FatalError(`Login Órbita falhou: ${errorMessage.trim()}`);
        }
        throw new RetryableError('Login Órbita falhou ou página inesperada após login.');
      }, {
        retryOn: (err) => err instanceof RetryableError || err.message.includes('timeout')
      });
    } catch (error) {
      if (error instanceof FatalError) throw error;
      throw new FatalError(`Falha crítica ao tentar login no Órbita: ${error.message}`);
    }
  }

  /**
   * @description Simula o envio de um arquivo Excel para o portal Órbita.
   *              (A implementação real de upload para Órbita dependeria da interface do site).
   * @param {string} filePath - Caminho do arquivo Excel a ser "enviado".
   * @param {string} fileName - Nome do arquivo.
   * @param {Array} data - Dados que seriam enviados.
   * @throws {RetryableError} Se houver um erro temporário no envio.
   * @throws {FatalError} Se o envio falhar permanentemente.
   */
  async uploadExcel(filePath, fileName, data) {
    logStructured('INFO', `Simulando envio do arquivo Excel "${fileName}" para o portal Órbita...`, { filePath, fileName });
    try {
      // A implementação real aqui dependeria da interface de upload do site Órbita.
      // Por exemplo:
      // await this.page.locator('input[type="file"]').setInputFiles(filePath);
      // await this.page.click('button[id="btnUpload"]');
      // await this.page.waitForSelector('.upload-success-message');

      // Como não temos a interface, apenas logamos o sucesso simulado.
      await new Promise(resolve => setTimeout(resolve, 2000)); // Simula um delay de upload
      logStructured('SUCCESS', `Arquivo Excel "${fileName}" simulado como enviado para Órbita.`, { registros: data.length });
    } catch (error) {
      throw new FatalError(`Falha ao simular envio de Excel para Órbita: ${error.message}`);
    }
  }
}

/**
 * @class DriveService
 * @description Serviço para interagir com o Google Drive via Google Apps Script.
 */
class DriveService {
  /**
   * @param {string} googleScriptUrl - URL do Google Apps Script para upload.
   */
  constructor(googleScriptUrl) {
    this.googleScriptUrl = googleScriptUrl;
  }

  /**
   * @description Envia um arquivo para o Google Drive via Google Apps Script.
   * @param {string} filePath - Caminho do arquivo local.
   * @param {string} fileName - Nome do arquivo no Drive.
   * @param {string} folderName - Nome da pasta no Drive.
   * @returns {Promise} Resposta da API do Google Apps Script.
   * @throws {RetryableError} Se houver um erro temporário no upload.
   * @throws {FatalError} Se o upload falhar permanentemente.
   */
  async uploadFile(filePath, fileName, folderName) {
    logStructured('INFO', `Iniciando upload do arquivo "${fileName}" para o Google Drive na pasta "${folderName}"...`, { filePath, fileName, folderName });
    try {
      const fileContent = fs.readFileSync(filePath).toString('base64');
      const payload = {
        action: 'uploadFile',
        fileName: fileName,
        folderName: folderName,
        fileContent: fileContent
      };

      const response = await withRetry(async () => {
        const res = await fetch(this.googleScriptUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
          timeout: 120000 // 2 minutos de timeout para upload
        });
        if (!res.ok) {
          const errorText = await res.text();
          if (res.status >= 500) { // Erros de servidor são retentáveis
            throw new RetryableError(`Erro no Google Script (status ${res.status}): ${errorText}`);
          }
          throw new FatalError(`Erro no Google Script (status ${res.status}): ${errorText}`);
        }
        return res.json();
      }, {
        retryOn: (err) => err instanceof RetryableError || err.message.includes('timeout')
      });

      if (response.status === 'success') {
        logStructured('SUCCESS', `Arquivo "${fileName}" enviado com sucesso para o Google Drive.`, { fileId: response.fileId });
      } else {
        throw new FatalError(`Google Script reportou falha no upload: ${response.message}`);
      }
      return response;
    } catch (error) {
      if (error instanceof FatalError) throw error;
      throw new FatalError(`Falha crítica ao enviar arquivo para o Google Drive: ${error.message}`);
    }
  }

  /**
   * @description Envia um arquivo de log para o Google Drive via Google Apps Script.
   * @param {string} logFilePath - Caminho do arquivo de log local.
   * @returns {Promise} Resposta da API do Google Apps Script.
   * @throws {RetryableError} Se houver um erro temporário no upload.
   * @throws {FatalError} Se o upload falhar permanentemente.
   */
  async uploadLog(logFilePath) {
    const logFileName = path.basename(logFilePath);
    logStructured('INFO', `Iniciando upload do arquivo de log "${logFileName}" para o Google Drive...`, { logFilePath, logFileName });
    try {
      const fileContent = fs.readFileSync(logFilePath).toString('base64');
      const payload = {
        action: 'uploadFile',
        fileName: logFileName,
        folderName: 'Logs do Robô', // Pasta dedicada para logs
        fileContent: fileContent
      };

      const response = await withRetry(async () => {
        const res = await fetch(this.googleScriptUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
          timeout: 60000 // 1 minuto de timeout
        });
        if (!res.ok) {
          const errorText = await res.text();
          if (res.status >= 500) {
            throw new RetryableError(`Erro no Google Script (status ${res.status}): ${errorText}`);
          }
          throw new FatalError(`Erro no Google Script (status ${res.status}): ${errorText}`);
        }
        return res.json();
      }, {
        retryOn: (err) => err instanceof RetryableError || err.message.includes('timeout')
      });

      if (response.status === 'success') {
        logStructured('SUCCESS', `Arquivo de log "${logFileName}" enviado com sucesso para o Google Drive.`, { fileId: response.fileId });
      } else {
        throw new FatalError(`Google Script reportou falha no upload do log: ${response.message}`);
      }
      return response;
    } catch (error) {
      if (error instanceof FatalError) throw error;
      logStructured('ERROR', `Falha crítica ao enviar arquivo de log para o Google Drive: ${error.message}`);
      // Não relança para não interromper o fluxo principal por um erro de log
    }
  }
}

// --- SLACK NOTIFIER ---
const slackBreaker = new CircuitBreaker(3, 300000); // 3 falhas, 5 minutos de OPEN

/**
 * @function sendSlackNotification
 * @description Envia uma notificação para o Slack usando um webhook e Circuit Breaker.
 * @param {string} message - A mensagem a ser enviada.
 */
async function sendSlackNotification(message) {
  logStructured('INFO', 'Tentando enviar notificação para o Slack...');
  try {
    await slackBreaker.execute(async () => {
      const response = await fetch(process.env.SLACK_WEBHOOK, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text: message }),
        timeout: 10000 // 10 segundos de timeout para Slack
      });

      if (!response.ok) {
        const errorText = await response.text();
        if (response.status >= 500 || response.status === 429) { // 429 Too Many Requests é retentável
          throw new RetryableError(`Erro ao enviar para Slack (status ${response.status}): ${errorText}`);
        }
        throw new FatalError(`Erro fatal ao enviar para Slack (status ${response.status}): ${errorText}`);
      }
      logStructured('SUCCESS', 'Notificação enviada para o Slack com sucesso.');
    });
  } catch (error) {
    if (error instanceof FatalError) {
      logStructured('ERROR', `Não foi possível enviar notificação para o Slack (fatal): ${error.message}`);
    } else if (error instanceof RetryableError) {
      logStructured('WARN', `Não foi possível enviar notificação para o Slack (retryable, tentará novamente): ${error.message}`);
    } else {
      logStructured('WARN', `Circuit Breaker impediu envio para Slack: ${error.message}`);
    }
  }
}

/**
 * @function checkAnomalies
 * @description Verifica métricas de execução para identificar e alertar sobre anomalias.
 * @param {ExecutionMetrics} metrics - Instância de ExecutionMetrics com os dados da execução.
 */
async function checkAnomalies(metrics) {
  const summary = metrics.summary();
  let anomalyMessages = [];

  // Alerta se execução muito lenta (ex: > 5 minutos)
  if (summary.totalDuration > 300000) {
    anomalyMessages.push(`⚠️ *Execução Lenta Detectada*: Duração total: ${(summary.totalDuration / 1000).toFixed(2)}s.`);
  }

  // Alerta se taxa de sucesso de eventos for baixa (ex: < 80%)
  if (summary.successRate < 0.8) {
    anomalyMessages.push(`⚠️ *Baixa Taxa de Sucesso*: ${Math.round(summary.successRate * 100)}% dos eventos falharam.`);
  }

  // Alerta se nenhum registro foi extraído
  const extractedRecords = summary.events
    .filter(e => e.name === 'extractReport' && e.status === 'success' && e.records !== undefined)
    .reduce((sum, e) => sum + e.records, 0);

  if (extractedRecords === 0) {
    anomalyMessages.push(`⚠️ *Nenhum registro extraído*: Verifique a fonte de dados ou os seletores.`);
  } else if (extractedRecords > 10000) { // Exemplo: alerta se mais de 10.000 registros (pode ser anomalia)
    anomalyMessages.push(`⚠️ *Volume Anormal de Registros*: ${extractedRecords} registros extraídos.`);
  }

  if (anomalyMessages.length > 0) {
    const fullMessage = `*Relatório de Anomalias do Robô Assim*
${anomalyMessages.join('
')}
Detalhes: ${process.env.GITHUB_SERVER_URL}/${process.env.GITHUB_REPOSITORY}/actions/runs/${process.env.GITHUB_RUN_ID}`;
    await sendSlackNotification(fullMessage);
  }
}

// --- FUNÇÃO PRINCIPAL DO ROBÔ ---

/**
 * @function robo
 * @description Função principal que orquestra toda a execução do robô.
 */
async function robo() {
  const metrics = new ExecutionMetrics();
  let browser;
  let page;
  let logFilePath;

  try {
    // 1. Validar variáveis de ambiente
    const startEnvValidation = Date.now();
    validateEnv();
    metrics.recordEvent('envValidation', Date.now() - startEnvValidation, 'success');

    // 2. Verificar horário comercial
    if (!dentroDoHorario()) {
      logStructured('INFO', 'Robô fora do horário comercial. Encerrando execução.');
      await sendSlackNotification('ℹ️ Robô Assim: Execução fora do horário comercial. Encerrando.');
      return;
    }
    logStructured('INFO', 'Robô dentro do horário comercial. Iniciando execução.');

    // 3. Lançar navegador
    const startBrowserLaunch = Date.now();
    browser = await chromium.launch({ headless: true });
    page = await browser.newPage();
    metrics.recordEvent('browserLaunch', Date.now() - startBrowserLaunch, 'success');
    logStructured('INFO', 'Navegador Playwright iniciado em modo headless.');

    // 4. Instanciar serviços
    const assimService = new AssimService(page);
    const orbitaService = new OrbitaService(page);
    const driveService = new DriveService(process.env.GOOGLE_SCRIPT_URL);

    // 5. Login no portal Assim
    const startAssimLogin = Date.now();
    await assimService.login(process.env.ORBITA_USER, process.env.SENHA); // Assumindo que ORBITA_USER é o mesmo para Assim
    metrics.recordEvent('assimLogin', Date.now() - startAssimLogin, 'success');

    // 6. Extrair relatório Normal
    const startExtractNormal = Date.now();
    const dadosNormal = await assimService.extractReport('https://sirius.assim.com.br/assimcsp/autorizador/preresultado.csp');
    metrics.recordEvent('extractReport', Date.now() - startExtractNormal, 'success', { type: 'Normal', records: dadosNormal.length });

    // 7. Extrair relatório Prefeitura
    const startExtractPrefeitura = Date.now();
    const dadosPrefeitura = await assimService.extractReport('https://sirius.assim.com.br/assimcsp/autorizador/preresultado.csp?tipo=prefeitura'); // Exemplo de URL para prefeitura
    metrics.recordEvent('extractReport', Date.now() - startExtractPrefeitura, 'success', { type: 'Prefeitura', records: dadosPrefeitura.length });

    const allExtractedData = [...dadosNormal, ...dadosPrefeitura];
    logStructured('INFO', `Total de registros extraídos (Normal + Prefeitura): ${allExtractedData.length}`);

    if (allExtractedData.length === 0) {
      logStructured('WARN', 'Nenhum dado foi extraído. Encerrando sem gerar arquivos.');
      await sendSlackNotification('⚠️ Robô Assim: NENHUM dado extraído. Verifique o portal Assim.');
      return;
    }

    // 8. Gerar arquivo Excel
    const startExcelGen = Date.now();
    const ws = XLSX.utils.json_to_sheet(allExtractedData);
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, 'RelatorioAssim');
    const excelFileName = `Relatorio_Assim_${new Date().toISOString().split('T')[0]}.xlsx`;
    const excelFilePath = path.join(__dirname, excelFileName);
    XLSX.writeFile(wb, excelFilePath);
    metrics.recordEvent('excelGeneration', Date.now() - startExcelGen, 'success', { fileName: excelFileName, records: allExtractedData.length });
    logStructured('SUCCESS', `Arquivo Excel "${excelFileName}" gerado com sucesso.`);

    // 9. Login no portal Órbita
    const startOrbitaLogin = Date.now();
    await orbitaService.login(process.env.ORBITA_USER, process.env.ORBITA_PASS);
    metrics.recordEvent('orbitaLogin', Date.now() - startOrbitaLogin, 'success');

    // 10. Enviar Excel para Órbita (simulado)
    const startOrbitaUpload = Date.now();
    await orbitaService.uploadExcel(excelFilePath, excelFileName, allExtractedData);
    metrics.recordEvent('orbitaUpload', Date.now() - startOrbitaUpload, 'success', { fileName: excelFileName });

    // 11. Enviar relatório para Google Drive
    const startDriveUpload = Date.now();
    await driveService.uploadFile(excelFilePath, excelFileName, 'Relatórios Assim');
    metrics.recordEvent('driveUpload', Date.now() - startDriveUpload, 'success', { fileName: excelFileName });

    // 12. Limpar arquivo local
    fs.unlinkSync(excelFilePath);
    logStructured('INFO', `Arquivo local "${excelFileName}" removido.`);

    logStructured('SUCCESS', 'Robô Assim: Execução concluída com sucesso!');
    await sendSlackNotification('✅ Robô Assim: Execução concluída com sucesso! Relatório enviado para Órbita e Drive.');

  } catch (error) {
    metrics.recordEvent('roboExecution', Date.now() - metrics.startTime, 'failure', { error: error.name, message: error.message });
    logStructured('ERROR', `Robô Assim: Falha na execução.`, {
      errorName: error.name,
      errorMessage: error.message,
      stack: error.stack
    });

    let slackMessage = `❌ *Robô Assim: Falha na execução!*
`;
    slackMessage += `*Erro:* ${error.name}: ${error.message}
`;
    if (process.env.GITHUB_RUN_ID) {
      slackMessage += `*Detalhes:* ${process.env.GITHUB_SERVER_URL}/${process.env.GITHUB_REPOSITORY}/actions/runs/${process.env.GITHUB_RUN_ID}
`;
    }
    await sendSlackNotification(slackMessage);

    // Se for um erro fatal, encerra o processo com código de erro
    if (error instanceof FatalError) {
      process.exit(1);
    }
  } finally {
    // 13. Fechar navegador
    if (browser) {
      await browser.close();
      logStructured('INFO', 'Navegador Playwright fechado.');
    }

    // 14. Enviar log para Google Drive
    logFilePath = path.join('logs', `${new Date().toISOString().split('T')[0]}.jsonl`);
    if (fs.existsSync(logFilePath)) {
      const driveService = new DriveService(process.env.GOOGLE_SCRIPT_URL);
      await driveService.uploadLog(logFilePath);
    }

    // 15. Verificar anomalias e enviar alerta
    await checkAnomalies(metrics);

    logStructured('INFO', 'Resumo final da execução:', metrics.summary());
  }
}

// --- EXECUÇÃO ---
(async () => {
  await robo();
})();
